{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd web && npm install && npm run build",
  "outputDirectory": "web/dist",
  "installCommand": "echo 'install handled in buildCommand'",
  "functions": {
    "api/scrape.py": {
      "maxDuration": 60,
      "regions": ["iad1"]
    },
    "api/deals.py": {
      "maxDuration": 10,
      "regions": ["iad1"]
    }
  },
  "crons": [
    {
      "path": "/api/scrape",
      "schedule": "0 13 * * *"
    }
  ]
}
